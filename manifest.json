{
    "manifest_version": 3,
    "name": "InstaBreak",
    "version": "1.0.0",
    "description": "This extension helps to stop endless scrolling on insta.",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": ["tabs", "storage"],
    "icons": {
        "16": "assets/pause.png"
    },
    "content_scripts": [
        {
            "matches": ["https://www.instagram.com/*"],
            "js": ["contentScript.js"],
            "css": ["content.css"]
        }
    ],
    "action": {
        "default_icon": {
            "16": "assets/pause.png"
        },
        "default_popup": "popup.html",
        "default_title": "InstaBreak"
    }
}